                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filter"
                    android:textColor="#1A1A1A"
                    android:textSize="12sp" />
                <ImageView
                    android:layout_width="14dp"
