<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="#FAFAFA">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageCard"
        android:layout_width="100dp"
        android:layout_height="130dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/cartProductImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_logo" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/cartProductName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:text="Product Name"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintEnd_toStartOf="@+id/btnRemove"
        app:layout_constraintStart_toEndOf="@+id/imageCard"
        app:layout_constraintTop_toTopOf="@+id/imageCard" />

    <TextView
        android:id="@+id/cartProductCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Product Category"
        android:textColor="#666666"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/cartProductName"
        app:layout_constraintTop_toBottomOf="@+id/cartProductName" />

    <TextView
        android:id="@+id/cartProductPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="LKR 0.00"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/cartProductName"
        app:layout_constraintTop_toBottomOf="@+id/cartProductCategory" />

    <LinearLayout
        android:id="@+id/spinnersLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="@+id/cartProductName"
        app:layout_constraintTop_toBottomOf="@+id/cartProductPrice">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#EFEFEF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical"
            app:cornerRadius="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Size "
                android:textColor="#333333"
                android:textSize="12sp" />
            <Spinner
                android:id="@+id/spinnerSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                android:minHeight="0dp"
                android:minWidth="0dp" />
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_arrow_down"
                app:tint="#666666" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="#EFEFEF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical"
            app:cornerRadius="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Color "
                android:textColor="#333333"
                android:textSize="12sp" />
            <Spinner
                android:id="@+id/spinnerColor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                android:minHeight="0dp"
                android:minWidth="0dp" />
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_arrow_down"
                app:tint="#666666" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/qtyLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#EFEFEF"
        android:paddingHorizontal="4dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:cornerRadius="8dp"
        app:layout_constraintStart_toStartOf="@+id/cartProductName"
        app:layout_constraintTop_toBottomOf="@+id/spinnersLayout">
        
        <ImageView
            android:id="@+id/btnQtyMinus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="6dp"
            android:src="@drawable/ic_minus"
            app:tint="#333333" />
            
        <TextView
            android:id="@+id/textQty"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />
            
        <ImageView
            android:id="@+id/btnQtyPlus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="6dp"
            android:src="@drawable/ic_plus"
            app:tint="#333333" />
    </LinearLayout>

    <TextView
        android:id="@+id/deliveryDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Delivery by 10 May 2XXX"
        android:textColor="#333333"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/cartProductName"
        app:layout_constraintTop_toBottomOf="@+id/qtyLayout" />

            <ImageView
                android:id="@+id/btnRemove"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                app:tint="#666666"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
